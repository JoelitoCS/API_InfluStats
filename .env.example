# Puerto del servidor backend.
PORT=3001

# URL de PostgreSQL/Supabase usada por Prisma.
DATABASE_URL="postgresql://postgres:password@localhost:5432/influStats"

# Clave para firmar JWT. Cambiar en produccion.
JWT_SECRET=tu_clave_secreta_super_segura_2026_cambiar_en_produccion

# ── SUPABASE STORAGE (NUEVO) ──────────────────────────────────────────────────
# URL del proyecto Supabase (Settings → API → Project URL)
SUPABASE_URL=https://xxxx.supabase.co

# Service Role Key (Settings → API → service_role) — NUNCA exponer al frontend
SUPABASE_SERVICE_KEY=eyJ...

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# Entorno de ejecucion.
ENVIRONMENT=development
