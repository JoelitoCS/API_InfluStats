# Puerto del servidor
PORT=3000

# Supabase PostgreSQL - Obtén en: https://supabase.com/dashboard/project/_/settings/database
# Formato: postgresql://[usuario]:[contraseña]@[host]:[puerto]/[base_datos]
DATABASE_URL="postgresql://postgres:password@localhost:5432/influStats"

# JWT Secret - Cambiar en producción a algo más seguro
JWT_SECRET=tu_clave_secreta_super_segura_2026_cambiar_en_produccion

# Ambiente
ENVIRONMENT=development
# ENVIRONMENT=production
