generator client {
  provider = "prisma-client-js"
}

// En Prisma 7 la URL va en prisma.config.ts, no aquí.
// El datasource solo declara el provider.
datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
//  User
// ─────────────────────────────────────────────────────────────────────────────
model User {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String          @unique
  passwordHash   String          @map("password_hash")
  name           String?
  role           String          @default("user")
  socialProfiles SocialProfile[]
  userProfile    UserProfile?
  createdAt      DateTime?       @default(now()) @map("created_at")
  lastLogin      DateTime?       @map("last_login")

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
//  UserProfile
// ─────────────────────────────────────────────────────────────────────────────
model UserProfile {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  username    String   @unique
  displayName String?  @map("display_name")
  bio         String?
  shortBio    String?  @map("short_bio")
  avatarUrl   String?  @map("avatar_url")
  avatarPath  String?  @map("avatar_path")
  country     String?
  isPublic    Boolean  @default(true) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  socialLinks SocialLink[]

  @@index([isPublic])
  @@index([username])
  @@map("user_profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
//  SocialLink
// ─────────────────────────────────────────────────────────────────────────────
model SocialLink {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId String      @map("profile_id") @db.Uuid
  profile   UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  platform  String
  url       String
  label     String?
  isPublic  Boolean  @default(true)  @map("is_public")
  isActive  Boolean  @default(true)  @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([profileId, platform])
  @@index([profileId, isPublic, isActive])
  @@map("social_links")
}

// ─────────────────────────────────────────────────────────────────────────────
//  SocialProfile
// ─────────────────────────────────────────────────────────────────────────────
model SocialProfile {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?          @map("user_id") @db.Uuid
  platform    String?
  username    String
  url         String
  needsUpdate Boolean          @default(false) @map("needs_update")
  createdAt   DateTime?        @default(now()) @map("created_at")
  user        User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  metrics     MetricsHistory[]

  @@index([userId])
  @@map("social_profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
//  MetricsHistory
// ─────────────────────────────────────────────────────────────────────────────
model MetricsHistory {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId  String    @map("profile_id") @db.Uuid
  weekDate   DateTime  @map("week_date") @db.Date
  engagement Decimal   @db.Decimal(5, 2)
  growth     Decimal?  @db.Decimal(8, 2)
  createdAt  DateTime? @default(now()) @map("created_at")

  profile   SocialProfile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  youtube   MetricsYoutube?
  tiktok    MetricsTiktok?
  twitch    MetricsTwitch?
  instagram MetricsInstagram?

  @@index([profileId, weekDate])
  @@map("metrics_history")
}

model MetricsYoutube {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  metricsId   String         @unique @map("metrics_id") @db.Uuid
  metrics     MetricsHistory @relation(fields: [metricsId], references: [id], onDelete: Cascade)

  views       Int
  likes       Int
  subscribers Int
  paidMembers Int     @map("paid_members")
  donations   Decimal @default(0) @map("donations") @db.Decimal(10, 2)

  @@map("metrics_youtube")
}

model MetricsTiktok {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  metricsId String         @unique @map("metrics_id") @db.Uuid
  metrics   MetricsHistory @relation(fields: [metricsId], references: [id], onDelete: Cascade)

  views     Int
  likes     Int
  comments  Int
  favorites Int
  shares    Int
  followers Int

  @@map("metrics_tiktok")
}

model MetricsTwitch {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  metricsId         String         @unique @map("metrics_id") @db.Uuid
  metrics           MetricsHistory @relation(fields: [metricsId], references: [id], onDelete: Cascade)

  views             Int
  followers         Int
  subscribersTwitch Int  @map("subscribers_twitch")
  bits              Int

  @@map("metrics_twitch")
}

model MetricsInstagram {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  metricsId String         @unique @map("metrics_id") @db.Uuid
  metrics   MetricsHistory @relation(fields: [metricsId], references: [id], onDelete: Cascade)

  views     Int
  likes     Int
  favorites Int
  followers Int
  posts     Int

  @@map("metrics_instagram")
}
